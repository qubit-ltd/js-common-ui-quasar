{
  "name": "@qubit-ltd/common-ui-quasar",
  "version": "1.1.3",
  "description": "The implementation of common UI components with the Quasar Framework",
  "author": "Haixing Hu (starfish.hu@gmail.com)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qubit-ltd/common-ui-quasar.git"
  },
  "bugs": {
    "url": "https://github.com/qubit-ltd/common-ui-quasar/issues"
  },
  "homepage": "https://github.com/qubit-ltd/common-ui-quasar",
  "keywords": [
    "JavaScript",
    "component",
    "quasar"
  ],
  "main": "dist/common-ui-quasar.cjs",
  "module": "dist/common-ui-quasar.mjs",
  "exports": {
    ".": {
      "require": "./dist/common-ui-quasar.cjs",
      "import": "./dist/common-ui-quasar.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**/*",
    "doc/**/*"
  ],
  "scripts": {
    "clean": "rm -rvf dist doc",
    "build": "cross-env NODE_ENV=production rollup -c rollup.config.mjs",
    "build:dev": "cross-env NODE_ENV=development rollup -c rollup.config.mjs",
    "build:all": "yarn clean && yarn doc && yarn build:dev && yarn build",
    "test": "jest",
    "lint": "eslint ./src ./test",
    "doc": "jsdoc -c jsdoc.json",
    "es5": "check-es-version -e 5 -s true",
    "deploy": "npm run lint && npm run test && npm run build:all && npm publish --registry='https://registry.npmjs.org/' --access public"
  },
  "peerDependencies": {
    "@babel/runtime": "^7.28.4",
    "@qubit-ltd/common-ui": "^1.15.3",
    "quasar": "^2.18.2",
    "vue": "^3.5.21"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.4",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/runtime": "^7.28.4",
    "@jest/core": "^30.1.3",
    "@qubit-ltd/common-ui": "^1.15.3",
    "@qubit-ltd/eslint-config": "^2.0.1",
    "@qubit-ltd/jsdoc-theme": "^1.5.2",
    "@qubit-ltd/logging": "^1.4.15",
    "@qubit-ltd/rollup-builder": "^1.8.14",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@vue/babel-preset-jsx": "^1.4.0",
    "@vue/compiler-dom": "^3.5.21",
    "@vue/compiler-sfc": "^3.5.21",
    "@vue/server-renderer": "^3.5.21",
    "@vue/test-utils": "^2.4.6",
    "@vue/vue3-jest": "^29.2.6",
    "babel-jest": "^29.7.0",
    "check-es-version": "^1.5.1",
    "core-js": "^3.45.1",
    "cross-env": "^10.0.0",
    "dayjs": "^1.11.18",
    "eslint": "^9.35.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.4.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-jsdom-global": "^4.0.0",
    "jest-extended": "^6.0.0",
    "jest-serializer-vue": "^3.1.0",
    "jsdoc": "^4.0.4",
    "quasar": "^2.18.2",
    "rollup": "^4.59.0",
    "rollup-plugin-analyzer": "^4.0.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "typescript": "^5.9.2",
    "vue": "^3.5.21",
    "vue-eslint-parser": "^10.2.0"
  },
  "packageManager": "yarn@4.5.0"
}
